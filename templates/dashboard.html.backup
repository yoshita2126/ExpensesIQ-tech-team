<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Expense Tracker Dashboard</title>
  <link rel="stylesheet" href="/static/style.css">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="dashboard-page">
  <aside class="sidebar">
    <div class="sidebar-logo">
      <div class="logo-icon">💰</div>
      <span class="logo-text">ExpensesIQ</span>
    </div>
    
    <nav class="sidebar-nav">
      <a href="{{ url_for('dashboard') }}" class="nav-item active">
        <span class="nav-icon">📊</span>
        <span class="nav-text">Dashboard</span>
      </a>
      <a href="{{ url_for('transactions_page') }}" class="nav-item">
        <span class="nav-icon">💳</span>
        <span class="nav-text">Transactions</span>
      </a>
      <a href="{{ url_for('budgets') }}" class="nav-item">
        <span class="nav-icon">🎯</span>
        <span class="nav-text">Budgets</span>
      </a>
      <a href="{{ url_for('goals_page') }}" class="nav-item">
        <span class="nav-icon">🎪</span>
        <span class="nav-text">Goals</span>
      </a>
      <a href="{{ url_for('calendar_page') }}" class="nav-item">
        <span class="nav-icon">📅</span>
        <span class="nav-text">Calendar</span>
      </a>
    </nav>
    
    <div class="sidebar-footer">
      <div class="dropdown-menu" id="settingsMenu">
        <button class="dropdown-toggle">
          <span class="nav-icon">⚙️</span>
          <span class="nav-text">Settings</span>
        </button>
        <div class="dropdown-content">
          <a href="{{ url_for('profile') }}">
            <span>👤</span>
            <span>Profile</span>
          </a>
          <a href="{{ url_for('preferences') }}">
            <span>🔔</span>
            <span>Preferences</span>
          </a>
          <a href="{{ url_for('help_support') }}">
            <span>❓</span>
            <span>Help & Support</span>
          </a>
          <a href="/logout" style="border-top: 1px solid rgba(255,255,255,0.1); color: #ef4444;">
            <span>🚪</span>
            <span>Logout</span>
          </a>
        </div>
      </div>
    </div>
  </aside>

  <main class="dashboard-main">
    <header class="dashboard-header">
      <div class="header-left">
        <h1>Dashboard</h1>
        <span class="header-subtitle">Welcome back, {{user}}!</span>
      </div>
    </header>

    <section class="dashboard-content">
      {% if alert %}
        <div class="alert-banner">{{alert}}</div>
      {% endif %}

      <form method="get" class="date-range-form">
        <label>From
          <input type="date" name="date_from" value="{{filter_from}}">
        </label>
        <label>To
          <input type="date" name="date_to" value="{{filter_to}}">
        </label>
        <button type="submit" class="form-btn">Apply</button>
        <a href="/dashboard" class="form-btn button-secondary" style="text-decoration:none;">Reset</a>
      </form>

      <!-- Summary Cards Grid with Icons -->
      <div class="metrics-grid">
        <div class="metric-card">
          <div class="metric-top-bar"></div>
          <div class="metric-icon-wrapper">
            <span class="metric-icon">📉</span>
          </div>
          <div class="metric-header">
            <span class="metric-title">Expenses</span>
          </div>
          <div class="metric-value">₹{{total_expense}}</div>
          <div class="metric-subtitle">Daily limit: ₹{{member_limit}}</div>
        </div>

        <div class="metric-card">
          <div class="metric-top-bar" style="background: linear-gradient(90deg, #7c3aed, #0ea5e9);"></div>
          <div class="metric-icon-wrapper" style="background: linear-gradient(135deg, #e0e7ff, #cffafe);">
            <span class="metric-icon">📄</span>
          </div>
          <div class="metric-header">
            <span class="metric-title">Income</span>
          </div>
          <div class="metric-value">₹{{total_income}}</div>
          <div class="metric-subtitle">Business and household income</div>
        </div>

        <div class="metric-card">
          <div class="metric-top-bar" style="background: linear-gradient(90deg, #f59e0b, #ec4899);"></div>
          <div class="metric-icon-wrapper" style="background: linear-gradient(135deg, #fef3c7, #fce7f3);">
            <span class="metric-icon">💰</span>
          </div>
          <div class="metric-header">
            <span class="metric-title">Net Savings</span>
          </div>
          <div class="metric-value">₹{{net_balance}}</div>
          <div class="metric-subtitle">{{ 'Positive balance' if net_balance >= 0 else 'Watch your spending' }}</div>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="dashboard-grid three-column">
        <div class="dashboard-card">
          <div class="card-header">
            <h2>Add Transaction</h2>
          </div>
          <form method="post" class="dashboard-form">
            <input type="hidden" name="action" value="transaction">
            <div class="form-group">
              <select class="form-select" name="type" id="type">
                <option value="expense">Expense</option>
                <option value="income">Income</option>
              </select>
            </div>
            <div class="form-group">
              <input class="form-input" id="amount" name="amount" type="number" step="0.01" placeholder="Amount" required>
            </div>
            <div class="form-group">
              <select class="form-select" id="category" name="category" required>
                <option value="" disabled selected>Select category</option>
                <option>Food</option>
                <option>Groceries</option>
                <option>Transportation</option>
                <option>Healthcare</option>
                <option>Education</option>
                <option>Rent</option>
                <option>Utilities</option>
                <option>Insurance</option>
                <option>Entertainment</option>
                <option>Dining</option>
                <option>Shopping</option>
                <option>Travel</option>
                <option>Investment</option>
                <option>Salary</option>
                <option>Bonus</option>
                <option>Freelance</option>
                <option>Other</option>
              </select>
            </div>
            <div class="form-group">
              <input class="form-input" id="note" name="note" type="text" placeholder="Note (optional)">
            </div>
            <button type="submit" class="form-btn primary">SAVE</button>
          </form>
        </div>

        <div class="dashboard-card">
          <div class="card-header">
            <h2>Set Goal</h2>
          </div>
          <form method="post" class="dashboard-form">
            <input type="hidden" name="action" value="goal">
            <div class="form-group">
              <input class="form-input" id="title" name="title" type="text" placeholder="Goal name" required>
            </div>
            <div class="form-group">
              <input class="form-input" id="target" name="target" type="number" step="0.01" placeholder="Target amount" required>
            </div>
            <div class="form-group">
              <input class="form-input" id="saved" name="saved" type="number" step="0.01" value="0" placeholder="0">
            </div>
            <div class="form-group">
              <input class="form-input" id="due_date" name="due_date" type="date" placeholder="dd-mm-yyyy">
            </div>
            <button type="submit" class="form-btn primary">ADD GOAL</button>
          </form>
        </div>

        <div class="dashboard-card">
          <div class="card-header">
            <h2>Your Daily Limit</h2>
          </div>
          <div class="metric-value" style="margin-bottom: 24px; font-size: 28px;">₹{{member_limit}}</div>
          <form method="post" class="dashboard-form">
            <input type="hidden" name="action" value="set_limit">
            <div class="form-group">
              <input class="form-input" id="daily_limit" name="daily_limit" type="number" step="0.01" placeholder="1000.0" value="{{member_limit}}" required>
            </div>
            <button type="submit" class="form-btn primary">SAVE</button>
          </form>
        </div>
      </div>

      <!-- Main Grid with Charts -->
      <div class="dashboard-grid">
        <!-- Expense Overview Chart -->
        <div class="dashboard-card">
          <div class="card-header">
            <h2>Expense Overview</h2>
            <div class="card-filter">This Month</div>
          </div>
          <div class="chart-container">
            <canvas id="categoryChart" width="280" height="280"></canvas>
          </div>
        </div>

        <!-- Monthly Trends Chart -->
        <div class="dashboard-card">
          <div class="card-header">
            <h2>Monthly Trends</h2>
            <div class="card-filter">This Year</div>
          </div>
          <div class="trend-legend">
            <span class="legend-item income">Income</span>
            <span class="legend-item expense">Expenses</span>
          </div>
          <div class="chart-container">
            <canvas id="trendsChart" width="100%" height="250"></canvas>
          </div>
        </div>
      </div>

      <!-- Bottom Grid -->
      <div class="dashboard-grid">
        <!-- Recent Transactions -->
        <div class="dashboard-card">
          <div class="card-header">
            <h2>Recent Transactions</h2>
            <a href="#" class="view-link">View All Transactions</a>
          </div>
          <div class="transactions-list">
            {% if transactions %}
              {% for trx in transactions[:5] %}
              <div class="transaction-item">
                <div class="transaction-icon">{% if trx.type == 'expense' %}📉{% else %}📈{% endif %}</div>
                <div class="transaction-details">
                  <div class="transaction-category">{{trx.category}}</div>
                  <div class="transaction-date">{{trx.date}}</div>
                </div>
                <div class="transaction-amount {% if trx.type == 'expense' %}negative{% else %}positive{% endif %}">
                  {% if trx.type == 'expense' %}-{% else %}+{% endif %}₹{{trx.amount}}
                </div>
              </div>
              {% endfor %}
            {% else %}
              <p class="empty-state">No transactions yet</p>
            {% endif %}
          </div>
        </div>

        <!-- Top Categories -->
        <div class="dashboard-card">
          <div class="card-header">
            <h2>Top Categories</h2>
            <a href="#" class="view-link">View All</a>
          </div>
          <div class="categories-list">
            {% if category_data %}
              {% set total = 0 %}
              {% for item in category_data %}
                {% set total = total + item.amount %}
              {% endfor %}
              {% for item in category_data[:5] %}
                {% set pct = (item.amount / total * 100) if total else 0 %}
                <div class="category-item">
                  <div class="category-info">
                    <span class="category-name">{{item.category}}</span>
                    <span class="category-amount">₹{{item.amount}}</span>
                  </div>
                  <div class="category-bar">
                    <div class="category-fill" style="width: {{pct}}%"></div>
                  </div>
                  <span class="category-percent">{{pct|round(1)}}%</span>
                </div>
              {% endfor %}
            {% else %}
              <p class="empty-state">No category data yet</p>
            {% endif %}
          </div>
        </div>
      </div>
    </section>

  </main>

  <script>
    // Render category pie chart
    let categoryData;
    try {
      categoryData = {{ category_data|default([])|tojson }} || [];
    } catch (e) {
      categoryData = [];
    }

    // Build labels and colors; include type in label and color by type
    const labels = categoryData.map(i => `${i.category} (${i.type || 'expense'})`);
    const data = categoryData.map(i => i.amount);
    const colors = categoryData.map((i, idx) => {
      if ((i.type || 'expense').toLowerCase() === 'income') return '#10b981';
      if ((i.type || 'expense').toLowerCase() === 'expense') return '#ef4444';
      return `hsl(${idx * 45}, 70%, 50%)`;
    });

    const categoryCtx = document.getElementById('categoryChart');
    if (categoryCtx && labels.length) {
      new Chart(categoryCtx, {
        type: 'doughnut',
        data: {
          labels: labels,
          datasets: [{
            data: data,
            backgroundColor: colors,
            borderColor: '#fff',
            borderWidth: 2,
          }]
        },
        options: {
          responsive: true,
          maintainAspectRatio: true,
          plugins: {
            legend: { 
              position: 'bottom',
              labels: { color: '#64748b', padding: 15 }
            }
          }
        }
      });
    }

    // Render trends line chart using server-provided data
    const trendsCtx = document.getElementById('trendsChart');
    try {
      const trendsLabels = {{ trends_labels|tojson|safe }} || [];
      const trendsIncome = {{ trends_income|tojson|safe }} || [];
      const trendsExpenses = {{ trends_expenses|tojson|safe }} || [];

      if (trendsCtx && trendsLabels.length) {
        new Chart(trendsCtx, {
          type: 'line',
          data: {
            labels: trendsLabels,
            datasets: [
              {
                label: 'Income',
                data: trendsIncome,
                borderColor: '#10b981',
                backgroundColor: 'rgba(16, 185, 129, 0.1)',
                tension: 0.4,
                fill: true,
                borderWidth: 3,
                pointRadius: 4,
                pointBackgroundColor: '#10b981'
              },
              {
                label: 'Expenses',
                data: trendsExpenses,
                borderColor: '#ef4444',
                backgroundColor: 'rgba(239, 68, 68, 0.1)',
                tension: 0.4,
                fill: true,
                borderWidth: 3,
                pointRadius: 4,
                pointBackgroundColor: '#ef4444'
              }
            ]
          },
          options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
              y: {
                beginAtZero: true,
                ticks: { color: '#64748b' },
                grid: { color: 'rgba(0,0,0,0.05)' }
              },
              x: {
                ticks: { color: '#64748b' },
                grid: { display: false }
              }
            },
            plugins: {
              legend: { 
                labels: { color: '#64748b', usePointStyle: true, padding: 15 }
              }
            }
          }
        });
      }
    } catch (e) {
      console.error('Failed to render trends chart', e);
    }
    
    // Settings dropdown menu toggle
    const settingsMenu = document.getElementById('settingsMenu');
    const dropdownToggle = settingsMenu.querySelector('.dropdown-toggle');
    
    if (dropdownToggle) {
      dropdownToggle.addEventListener('click', function(e) {
        e.preventDefault();
        settingsMenu.classList.toggle('active');
      });
      
      // Close dropdown when clicking outside
      document.addEventListener('click', function(e) {
        if (!settingsMenu.contains(e.target)) {
          settingsMenu.classList.remove('active');
        }
      });
    }
  </script>
</body>
</html>
